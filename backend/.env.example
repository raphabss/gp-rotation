# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
CORS_ORIGIN=*

# ─── Webhook ──────────────────────────────────────────────────────────────────
# Secret shared with Power Automate. Change this to a strong random string.
WEBHOOK_SECRET=spingaming-2024-change-me

# ─── Microsoft Graph API (Fase 2 - Backlog) ───────────────────────────────────
# Set GRAPH_ENABLED=true after configuring the App Registration no Entra ID
GRAPH_ENABLED=false

# App Registration credentials (Entra ID > App Registrations > gp-rotation-app)
GRAPH_TENANT_ID=your-tenant-id-here
GRAPH_CLIENT_ID=your-client-id-here
GRAPH_CLIENT_SECRET=your-client-secret-here

# SharePoint file location
# Site ID: GET https://graph.microsoft.com/v1.0/sites?search=cassino
GRAPH_SITE_ID=spingaming.sharepoint.com,site-id-here

# Path to the Excel file within the SharePoint drive
# Example: /Documentos Compartilhados/Rotacao GPs.xlsx
GRAPH_FILE_PATH=/Shared Documents/Rotacao GPs.xlsx

# Name of the worksheet tab
GRAPH_SHEET_NAME=

# ─── Autenticação ─────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-aleatoria-forte

# ─── Ambiente QA (opcional) ───────────────────────────────────────────────────
# Aba da planilha usada pelo ambiente de homologação (/qa/tv)
GRAPH_SHEET_NAME_QA=
