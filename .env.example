# Copie para .env e preencha. NUNCA faça commit do .env real.

# Porta exposta no host (acesse http://IP-DO-LXC:porta)
LISTEN_PORT=80

# Intervalo de sync com o SharePoint (ms). Padrao 15000 (15s).
SYNC_INTERVAL_MS=15000

# Fuso horario do container (necessario p/ os cortes de turno)
TZ=America/Sao_Paulo

# Secret de webhook (legado). Troque por algo forte se usar.
WEBHOOK_SECRET=troque-por-uma-string-forte

# Microsoft Graph (App Registration / client credentials)
GRAPH_ENABLED=false
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SITE_ID=
GRAPH_FILE_PATH=/Rotação/Month Shift and Rotation.xlsx
GRAPH_SHEET_NAME=Template TV
# Aba de QA (opcional)
GRAPH_SHEET_NAME_QA=

# Segredo de assinatura dos tokens JWT (gere um forte e aleatorio)
JWT_SECRET=troque-por-uma-string-aleatoria-longa
